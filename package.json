{
  "name": "starlight-tech-radar",
  "version": "0.0.1",
  "description": "This project is an open source tech radar, inspired by the ThoughtWorks Tech Radar.",
  "productName": "Starlight Tech Radar",
  "author": "\"Ele\" <starlight-tech-radar@ele.codes>",
  "type": "module",
  "private": false,
  "license": "MIT",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:unit",
    "test:update": "vitest run --update",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "type-check": "vue-tsc --noEmit",
    "test:all": "npm run type-check && npm run test:unit && npm run test:e2e",
    "wiremock:up": "docker compose up -d",
    "wiremock:down": "docker compose down",
    "dev": "quasar dev -m ssr",
    "build": "quasar build -m ssr",
    "postinstall": "quasar prepare && npx playwright install",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,cjs,mjs,vue}": [
      "eslint --fix",
      "vitest related --run"
    ]
  },
  "dependencies": {
    "@blueoak/list": "^15.0.0",
    "@fontsource/opendyslexic": "^5.2.5",
    "@quasar/extras": "^1.16.4",
    "axios": "^1.2.1",
    "pinia": "^3.0.1",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-i18n": "^11.0.0",
    "vue-router": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.14.0",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.58.2",
    "@quasar/app-vite": "^2.1.0",
    "@types/node": "^20.5.9",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/eslint-config-typescript": "^14.4.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.2",
    "axe-core": "^4.11.1",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "neostandard": "^0.12.2",
    "typescript": "^5.9.2",
    "vite-plugin-checker": "^0.11.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.7"
  },
  "engines": {
    "node": "^24",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}
