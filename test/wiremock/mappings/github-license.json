{
  "request": {
    "method": "GET",
    "urlPathPattern": "/repos/.*/license"
  },
  "response": {
    "status": 200,
    "jsonBody": {
      "license": {
        "key": "mit",
        "name": "MIT License",
        "spdx_id": "MIT",
        "url": "https://api.github.com/licenses/mit"
      },
      "html_url": "https://github.com/test/repo/blob/main/LICENSE"
    },
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
